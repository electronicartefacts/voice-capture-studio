{
  "name": "voice-capture-studio",
  "version": "0.1.0",
  "description": "Local-first browser studio for directed voice capture and dataset-ready metadata.",
  "license": "MIT",
  "author": "Electronic Artefacts",
  "type": "module",
  "homepage": "https://electronicartefacts.github.io/voice-capture-studio/",
  "repository": {
    "type": "git",
    "url": "https://github.com/electronicartefacts/voice-capture-studio.git"
  },
  "bugs": {
    "url": "https://github.com/electronicartefacts/voice-capture-studio/issues"
  },
  "keywords": [
    "audio",
    "dataset",
    "local-first",
    "react",
    "voice-capture",
    "web-audio"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build && node check-build-budget.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "preview": "vite preview --host 127.0.0.1",
    "serve": "npm run build && vite preview --host 127.0.0.1",
    "test": "node --import tsx --test tests/*.test.ts",
    "test:coverage": "node --import tsx --test --experimental-test-coverage --test-coverage-include='src/**/*.ts' --test-coverage-exclude='src/**/*.tsx' --test-coverage-lines=90 --test-coverage-branches=80 --test-coverage-functions=85 tests/*.test.ts",
    "test:e2e": "playwright test",
    "typecheck": "tsc -b --pretty false",
    "validate": "npm run format:check && npm run lint && npm run typecheck && npm run test:coverage && npm run build"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "onnxruntime-web": "^1.26.0-dev.20260416-b7804b056c",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "tsx": "^4.23.0",
    "typescript-eslint": "^8.63.0"
  }
}
